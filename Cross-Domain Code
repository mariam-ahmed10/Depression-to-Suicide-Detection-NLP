def find_data_root(base):
    for item in os.listdir(base):
        if item.startswith('__'):
            continue
        full = os.path.join(base, item)
        if os.path.isdir(full):
            sub = os.listdir(full)
            if 'positive' in sub or 'negative' in sub:
                return full
    return base

